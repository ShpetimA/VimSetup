{
    "diffEditor.renderSideBySide": false,
    //VIM
    "vim.leader": "<Space>",
    "vim.highlightedyank.enable": true,
    "vim.highlightedyank.color": "rgba(0, 100, 100, 0.3)",
    "vim.hlsearch": true,
    "vim.normalModeKeyBindingsNonRecursive": [
        // switch b/w buffers
        { "before": ["<S-h>"], "commands": [":bprevious"] },
        { "before": ["<S-l>"], "commands": [":bnext"] },
        //panes
        { "before": ["leader", "v"], "commands": [":vsplit"] },
        { "before": ["leader", "s"], "commands": [":split"] },
        //move between panes
        { "before": ["<C-h>"], "after": ["<C-w>", "h"] },
        { "before": ["<C-j>"], "after": ["<C-w>", "j"] },
        { "before": ["<C-k>"], "after": ["<C-w>", "k"] },
        { "before": ["<C-l>"], "after": ["<C-w>", "l"] },
        //nice to have
        { "before": ["leader", "q"], "commands": [":q!"] },
        { "before": ["leader", "w", "q"], "commands": [":wq"] },
        {
            "before": ["leader", "p"],
            "commands": ["workbench.action.quickOpen"]
        },
        {
            "before": ["leader", "f"],
            "commands": ["editor.action.formatDocument"]
        },
        {
            "before": ["<leader>", "c", "a"],
            "commands": ["editor.action.quickFix"]
        },

        { "before": ["[", "d"], "commands": ["editor.action.marker.prev"] },
        { "before": ["]", "d"], "commands": ["editor.action.marker.next"] },
        {
            "before": ["<leader>", "m"],
            "commands": ["whichkey.show"]
        },
        {
            "before": ["J"],
            "after": ["5", "j"]
        },
        {
            "before": ["K"],
            "after": ["5", "k"]
        },
        {
            "before": ["<Leader>", "j"],
            "after": ["J"]
        },
        {
            "before": ["<Leader>", "t", "t"],
            "commands": [":tabnew"]
        },
        {
            "before": ["<Leader>", "t", "o"],
            "commands": [":tabo"]
        },
        {
            "before": ["<Leader>", "/"],
            "commands": [":noh"]
        },
        {
            "before": ["<Leader>", "w"],
            "commands": ["workbench.action.files.save"]
        },
        {
            "before": ["<Leader>", "t"],
            "commands": ["workbench.action.gotoSymbol"]
        },
        {
            "before": ["<Leader>", "r", "e"],
            "commands": ["editor.action.rename"]
        }
    ],
    "vim.visualModeKeyBindings": [
        // Stay in visual mode while indenting
        { "before": ["<"], "commands": ["editor.action.outdentLines"] },
        { "before": [">"], "commands": ["editor.action.indentLines"] },
        // toggle comment selection
        { "before": ["leader", "c"], "commands": ["editor.action.commentLine"] }
    ],
    "vim.insertModeKeyBindingsNonRecursive": [],
    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": ["<Leader>", "m"],
            "commands": ["whichkey.show"]
        },
        {
            "before": ["J"],
            "after": ["5", "j"]
        },
        {
            "before": ["K"],
            "after": ["5", "k"]
        }
    ],

    "chat.setupFromDialog": false,
    "zenMode.centerLayout": false,
    "zenMode.hideLineNumbers": false,
    "zenMode.fullScreen": false,
    //INDENT
    "workbench.colorTheme": "Gruvbox Dark Hard",
    "workbench.statusBar.visible": true,
    "editor.lineNumbers": "relative",
    "editor.glyphMargin": true,
    "editor.folding": true,

    "editor.guides.indentation": false,
    "workbench.colorCustomizations": {
        "editor.bracketPairColorization.enabled": false,
        "editor.guides.highlightActiveBracketPair": false,
        "editor.guides.bracketPairs": false,
        "workbench.tree.renderIndentGuides": "none",
        "editor.guides.indentation": true,
        "editorIndentGuide.activeBackground1": "#2a323f",
        "editorIndentGuide.background1": "#2a323f"
    },

    //FONT FAMILY
    "editor.fontSize": 16,
    "window.zoomLevel": 1,
    "editor.fontLigatures": false,
    "editor.lineHeight": 1.3,
    "editor.fontFamily": "TX-02,Jetbrains Mono",
    "terminal.integrated.fontFamily": "Jetbrains Mono Nerd Font",

    "breadcrumbs.enabled": false,
    "window.customTitleBarVisibility": "never",
    "editor.minimap.enabled": false,
    "window.commandCenter": false,
    "editor.scrollbar.vertical": "auto",
    "editor.scrollbar.horizontal": "auto",
    "workbench.sideBar.location": "right",
    "workbench.startupEditor": "none",
    "explorer.compactFolders": false,
    "files.trimTrailingWhitespace": true,
    "workbench.settings.applyToAllProfiles": [],
    "editor.linkedEditing": true,
    "editor.suggest.insertMode": "replace",
    "extensions.autoUpdate": "onlyEnabledExtensions",
    "extensions.ignoreRecommendations": true,
    "editor.scrollBeyondLastLine": false,
    "typescript.preferences.importModuleSpecifier": "non-relative",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "typescript.preferences.autoImportSpecifierExcludeRegexes": [
        "^react-native-reanimated/lib/*",
        "^expo-router/build/*",
        "^react-native-svg/*"
    ],
    "editor.stickyScroll.enabled": true,
    "workbench.tree.enableStickyScroll": true,
    "files.associations": {
        "*.pl": "prolog",
        "*.tmpl": "html",
        "*.odin": "odin"
    },
    "git.confirmSync": false,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
        "go": false,
        "r": false,
        "typescript": true,
        "rust": false,
        "haskell": false
    },
    "go.toolsManagement.autoUpdate": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            "*.mutable": {
                "underline": false
            }
        }
    },
    "[python]": {
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.formatOnType": true,
        "editor.wordBasedSuggestions": "off"
    },
    "python.REPL.enableREPLSmartSend": false,
    "gitlens.currentLine.enabled": false,
    "gitlens.hovers.currentLine.over": "line",
    "gitlens.codeLens.enabled": false,
    "projectManager.git.baseFolders": ["$home/"],
    "projectManager.sortList": "Recent",
    "github.copilot.editor.enableAutoCompletions": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "gitlens.views.contributors.showStatistics": true,
    "git.autofetch": true,
    "terminal.integrated.env.osx": {},
    "editor.inlayHints.enabled": "offUnlessPressed",
    "workbench.activityBar.location": "top",
    "gitlens.hovers.enabled": false,
    "zig.zls.enabled": "on",
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
        "Cargo.toml": "Cargo.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },

    "tailwindCSS.experimental.classRegex": [
        ["cva\\(((?:[^()]|\\([^()]*\\))*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"] ,
        ["cx\\(((?:[^()]|\\([^()]*\\))*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
    ],
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",
    "editor.inlineSuggest.edits.renderSideBySide": "never",
    //TMUX SHELL
    "terminal.integrated.profiles.osx": {
        "tmux-shell": {
            "path": "tmux",
            "args": ["new-session", "-A", "-s", "vscode:${workspaceFolder}"]
        }
    },
    //FORMATTING
    "prettier.jsxSingleQuote": true,
    "prettier.singleQuote": true,
    "prettier.semi": false,
    "prettier.trailingComma": "none",
    "prettier.tabWidth": 4,
    "prettier.arrowParens": "avoid",
    "prettier.documentSelectors": ["**/*.astro"],

    "[javascript]": {
        "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[css]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[astro]": {
        "editor.defaultFormatter": "astro-build.astro-vscode"
    },

    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },
    "eslint.workingDirectories": [
        {
            "mode": "auto"
        }
    ],
    "eslint.validate": ["javascript"],
    "gitlens.graph.dimMergeCommits": true,
    "haskell.manageHLS": "GHCup",
    "github.copilot.nextEditSuggestions.enabled": true,
    "[markdown]": {
        "editor.unicodeHighlight.ambiguousCharacters": false,
        "editor.unicodeHighlight.invisibleCharacters": false,
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "comments": "off",
            "strings": "off",
            "other": "off"
        },
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "yaml.schemas": {
        "file:///Users/shpetimalimi/.vscode/extensions/atlassian.atlascode-4.0.11/resources/schemas/pipelines-schema.json": "bitbucket-pipelines.yml"
    },
    "atlascode.helpExplorerEnabled": false,
    "atlascode.bitbucket.explorer.nestFilesEnabled": true,
    "atlascode.bitbucket.pipelines.monitorEnabled": false,
    "atlascode.rovodev.showEntitlementNotifications": false,
    "chat.tools.terminal.autoApprove": {
        "pnpm": true,
        "npx": true,
        "expo": true
    },
    "[odin]": {},
    "claudeCode.preferredLocation": "panel",
    "git.openRepositoryInParentFolders": "never",
    "json.schemaDownload.trustedDomains": {
        "https://schemastore.azurewebsites.net/": true,
        "https://raw.githubusercontent.com/": true,
        "https://www.schemastore.org/": true,
        "https://json.schemastore.org/": true,
        "https://json-schema.org/": true,
        "https://biomejs.dev": true
    }
}
